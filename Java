const CONFIG = {
  LIST_TITLE: "情報保証相談室", // ← 実際のリスト名に合わせて変更

  INTERNAL_NAMES: {
    title: "Title",
    category: "区分",
    questionBody: "質問内容",
    questioner: "質問者",
    phoneNumber: "電話番号",
    questionDate: "質問日",
    status: "ステータス",
    answerBody: "回答内容",
    answerDate: "回答日",
    answerer: "回答者"
  },

  STATUS_DEFAULT: "未対応",
  Q_PREFIX: "Q-",
  Q_DIGITS: 4,
  TOP_COUNT: 100
};

let currentUser = null;
let listItemEntityTypeFullName = null;

// ================================
// 共通
// ================================
function apiUrl(path) {
  return `../_api${path}`;
}

function setMessage(text, type = "info") {
  const el = document.getElementById("message");
  if (!el) return;
  el.className = `message ${type}`;
  el.textContent = text;
}

function clearMessage() {
  const el = document.getElementById("message");
  if (!el) return;
  el.className = "message";
  el.textContent = "";
}

function escapeHtml(value) {
  if (value === null || value === undefined) return "";
  return String(value)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function formatDate(value) {
  if (!value) return "";
  const d = new Date(value);
  if (isNaN(d.getTime())) return value;

  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  const hh = String(d.getHours()).padStart(2, "0");
  const mm = String(d.getMinutes()).padStart(2, "0");

  return `${y}/${m}/${day} ${hh}:${mm}`;
}

function makeQNumber(itemId) {
  return CONFIG.Q_PREFIX + String(itemId).padStart(CONFIG.Q_DIGITS, "0");
}

async function spFetch(url, options = {}) {
  const headers = Object.assign(
    {
      "Accept": "application/json;odata=verbose"
    },
    options.headers || {}
  );

  const response = await fetch(url, {
    credentials: "same-origin",
    ...options,
    headers
  });

  if (!response.ok) {
    const text = await response.text();
    throw new Error(`HTTP ${response.status}\n${text}`);
  }

  const contentType = response.headers.get("content-type") || "";
  if (contentType.indexOf("application/json") >= 0) {
    return await response.json();
  }

  return null;
}

async function getRequestDigest() {
  const data = await spFetch(apiUrl("/contextinfo"), {
    method: "POST",
    headers: {
      "Accept": "application/json;odata=verbose"
    }
  });

  return data.d.GetContextWebInformation.FormDigestValue;
}

async function getCurrentUser() {
  const data = await spFetch(apiUrl("/web/currentuser"));
  return data.d;
}

async function getListItemEntityTypeFullName() {
  const url = apiUrl(
    `/web/lists/getbytitle('${encodeURIComponent(CONFIG.LIST_TITLE)}')?$select=ListItemEntityTypeFullName`
  );
  const data = await spFetch(url);
  return data.d.ListItemEntityTypeFullName;
}

// ================================
// 登録処理
// ================================
function buildCreatePayload() {
  const categoryEl = document.getElementById("category");
  const phoneNumberEl = document.getElementById("phoneNumber");
  const questionBodyEl = document.getElementById("questionBody");

  if (!categoryEl || !phoneNumberEl || !questionBodyEl) {
    throw new Error("画面項目が見つかりません。HTMLのidを確認してください。");
  }

  const category = categoryEl.value.trim();
  const phoneNumber = phoneNumberEl.value.trim();
  const questionBody = questionBodyEl.value.trim();

  if (!category) {
    throw new Error("区分を選択してください。");
  }

  if (!questionBody) {
    throw new Error("質問内容を入力してください。");
  }

  const payload = {
    __metadata: { type: listItemEntityTypeFullName },
    [CONFIG.INTERNAL_NAMES.title]: "TEMP",
    [CONFIG.INTERNAL_NAMES.category]: category,
    [CONFIG.INTERNAL_NAMES.questionBody]: questionBody,
    [CONFIG.INTERNAL_NAMES.questioner + "Id"]: currentUser.Id,
    [CONFIG.INTERNAL_NAMES.questionDate]: new Date().toISOString(),
    [CONFIG.INTERNAL_NAMES.status]: CONFIG.STATUS_DEFAULT
  };

  if (phoneNumber) {
    payload[CONFIG.INTERNAL_NAMES.phoneNumber] = phoneNumber;
  }

  return payload;
}

async function createQuestionItem() {
  const digest = await getRequestDigest();
  const payload = buildCreatePayload();

  const url = apiUrl(
    `/web/lists/getbytitle('${encodeURIComponent(CONFIG.LIST_TITLE)}')/items`
  );

  const data = await spFetch(url, {
    method: "POST",
    headers: {
      "Accept": "application/json;odata=verbose",
      "Content-Type": "application/json;odata=verbose",
      "X-RequestDigest": digest
    },
    body: JSON.stringify(payload)
  });

  return data.d;
}

async function updateTitleToQNumber(itemId) {
  const digest = await getRequestDigest();
  const qNumber = makeQNumber(itemId);

  const url = apiUrl(
    `/web/lists/getbytitle('${encodeURIComponent(CONFIG.LIST_TITLE)}')/items(${itemId})`
  );

  await spFetch(url, {
    method: "POST",
    headers: {
      "Accept": "application/json;odata=verbose",
      "Content-Type": "application/json;odata=verbose",
      "X-RequestDigest": digest,
      "IF-MATCH": "*",
      "X-HTTP-Method": "MERGE"
    },
    body: JSON.stringify({
      __metadata: { type: listItemEntityTypeFullName },
      [CONFIG.INTERNAL_NAMES.title]: qNumber
    })
  });

  return qNumber;
}

async function submitQuestion() {
  clearMessage();

  const btn = document.getElementById("submitBtn");
  if (btn) btn.disabled = true;

  try {
    setMessage("登録中です...", "info");

    const created = await createQuestionItem();
    const itemId = created.Id;
    const qNumber = await updateTitleToQNumber(itemId);

    setMessage(`登録完了しました。\n管理番号: ${qNumber}`, "success");

    document.getElementById("category").value = "";
    document.getElementById("phoneNumber").value = "";
    document.getElementById("questionBody").value = "";

    await loadQuestions();
  } catch (err) {
    console.error(err);
    setMessage("登録に失敗しました。\n" + err.message, "error");
  } finally {
    if (btn) btn.disabled = false;
  }
}

// ================================
// 一覧表示（全ユーザ分表示）
// ================================
async function loadQuestions() {
  const area = document.getElementById("listArea");
  if (!area) return;

  area.textContent = "読込中...";

  try {
    const n = CONFIG.INTERNAL_NAMES;

    const selectFields = [
      "Id",
      n.title,
      n.category,
      n.questionBody,
      n.phoneNumber,
      n.questionDate,
      n.status,
      n.answerBody,
      n.answerDate,
      `${n.questioner}/Id`,
      `${n.questioner}/Title`,
      `${n.questioner}/EMail`,
      `${n.answerer}/Id`,
      `${n.answerer}/Title`,
      `${n.answerer}/EMail`
    ].join(",");

    const expandFields = [n.questioner, n.answerer].join(",");
    const orderby = `${n.questionDate} desc`;

    const url =
      apiUrl(`/web/lists/getbytitle('${encodeURIComponent(CONFIG.LIST_TITLE)}')/items`) +
      `?$select=${encodeURIComponent(selectFields)}` +
      `&$expand=${encodeURIComponent(expandFields)}` +
      `&$orderby=${encodeURIComponent(orderby)}` +
      `&$top=${CONFIG.TOP_COUNT}`;

    const data = await spFetch(url);
    const items = data.d.results || [];

    if (!items.length) {
      area.innerHTML = '<div class="muted">まだ質問はありません。</div>';
      return;
    }

    let html = `
      <table>
        <thead>
          <tr>
            <th class="nowrap">管理番号</th>
            <th class="nowrap">質問日</th>
            <th class="nowrap">区分</th>
            <th class="nowrap">質問者</th>
            <th>質問内容</th>
            <th class="nowrap">ステータス</th>
            <th>回答</th>
          </tr>
        </thead>
        <tbody>
    `;

    items.forEach(item => {
      const title = item[n.title] || "";
      const category = item[n.category] || "";
      const questionBody = item[n.questionBody] || "";
      const questionDate = formatDate(item[n.questionDate]);
      const status = item[n.status] || "";
      const answerBody = item[n.answerBody] || "";
      const questionerName = item[n.questioner] && item[n.questioner].Title
        ? item[n.questioner].Title
        : "";
      const answererName = item[n.answerer] && item[n.answerer].Title
        ? item[n.answerer].Title
        : "";
      const answerDate = item[n.answerDate] ? formatDate(item[n.answerDate]) : "";

      let answerHtml = '<span class="muted">未回答</span>';
      if (answerBody) {
        answerHtml =
          `${escapeHtml(answerBody).replace(/\n/g, "<br>")}` +
          (answererName ? `<div class="small muted">回答者: ${escapeHtml(answererName)}</div>` : "") +
          (answerDate ? `<div class="small muted">回答日: ${escapeHtml(answerDate)}</div>` : "");
      }

      html += `
        <tr>
          <td class="nowrap">${escapeHtml(title)}</td>
          <td class="nowrap">${escapeHtml(questionDate)}</td>
          <td class="nowrap">${escapeHtml(category)}</td>
          <td class="nowrap">${escapeHtml(questionerName)}</td>
          <td>${escapeHtml(questionBody).replace(/\n/g, "<br>")}</td>
          <td class="nowrap"><span class="status-badge">${escapeHtml(status)}</span></td>
          <td>${answerHtml}</td>
        </tr>
      `;
    });

    html += `
        </tbody>
      </table>
    `;

    area.innerHTML = html;
  } catch (err) {
    console.error(err);
    area.innerHTML = `<div style="color:#b42318;">一覧の読込に失敗しました。<br>${escapeHtml(err.message)}</div>`;
  }
}

// ================================
// 初期化
// ================================
async function init() {
  try {
    setMessage("初期化中です...", "info");

    currentUser = await getCurrentUser();
    listItemEntityTypeFullName = await getListItemEntityTypeFullName();

    const userNameEl = document.getElementById("currentUserName");
    const userEmailEl = document.getElementById("currentUserEmail");

    if (userNameEl) userNameEl.textContent = currentUser.Title || "";
    if (userEmailEl) userEmailEl.textContent = currentUser.Email || "";

    clearMessage();
    await loadQuestions();
  } catch (err) {
    console.error(err);

    const userNameEl = document.getElementById("currentUserName");
    if (userNameEl) userNameEl.textContent = "取得失敗";

    setMessage("初期化に失敗しました。\n" + err.message, "error");
  }
}

// ================================
// イベント登録
// ================================
window.addEventListener("load", function () {
  const submitBtn = document.getElementById("submitBtn");
  const reloadBtn = document.getElementById("reloadBtn");

  if (submitBtn) {
    submitBtn.addEventListener("click", submitQuestion);
  }

  if (reloadBtn) {
    reloadBtn.addEventListener("click", loadQuestions);
  }

  init();
});
