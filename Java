function debug(msg) {
  var el = document.getElementById("debugArea");
  if (el) {
    el.textContent += "\n" + msg;
  }
}

debug("JS start");

// ================================
// 設定
// ================================
var LIST_TITLE = "情報保証相談室";

var COL = {
  TITLE: "Title",
  QUESTION: "_x8cea__x554f__x5185__x5bb9_",
  ANSWER: "_x56de__x7b54__x5185__x5bb9_"
};

// ================================
// 共通
// ================================
function getBaseUrl() {
  var path = location.pathname;
  var idx = path.lastIndexOf("/");
  var folder = path.substring(0, idx);
  var site = folder.substring(0, folder.lastIndexOf("/"));
  return location.origin + site;
}

function api(path) {
  return getBaseUrl() + "/_api" + path;
}

function escapeHtml(value) {
  if (value === null || value === undefined) return "";
  return String(value)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function setMessage(text) {
  var el = document.getElementById("message");
  if (el) {
    el.innerHTML = escapeHtml(text);
  }
}

// HTML文字列からタグだけざっくり除去して見やすくする
function stripHtml(html) {
  if (html === null || html === undefined) return "";
  var div = document.createElement("div");
  div.innerHTML = html;
  return div.textContent || div.innerText || "";
}

// ================================
// XHR
// ================================
function xhrJson(method, url, body, extraHeaders, callback) {
  debug("xhr: " + method + " " + url);

  var xhr = new XMLHttpRequest();
  xhr.open(method, url, true);
  xhr.withCredentials = true;
  xhr.setRequestHeader("Accept", "application/json;odata=verbose");

  if (extraHeaders) {
    for (var k in extraHeaders) {
      if (extraHeaders.hasOwnProperty(k)) {
        xhr.setRequestHeader(k, extraHeaders[k]);
      }
    }
  }

  xhr.onreadystatechange = function () {
    if (xhr.readyState === 4) {
      debug("status: " + xhr.status);

      if (xhr.status >= 200 && xhr.status < 300) {
        var data = null;
        try {
          data = xhr.responseText ? JSON.parse(xhr.responseText) : null;
        } catch (e) {
          callback(new Error("JSON parse error: " + e.message));
          return;
        }
        callback(null, data);
      } else {
        callback(new Error("HTTP " + xhr.status + " " + xhr.responseText));
      }
    }
  };

  xhr.onerror = function () {
    callback(new Error("通信エラー"));
  };

  xhr.send(body || null);
}

// ================================
// API
// ================================
function getCurrentUser(callback) {
  xhrJson("GET", api("/web/currentuser"), null, null, callback);
}

function loadQuestions() {
  debug("loadQuestions start");

  var url = api("/web/lists/getbytitle('" + encodeURIComponent(LIST_TITLE) + "')/items?$orderby=ID desc&$top=100");

  xhrJson("GET", url, null, null, function (err, data) {
    var area = document.getElementById("listArea");
    if (!area) return;

    if (err) {
      debug("loadQuestions error: " + err.message);
      area.innerHTML = "<div style='color:red;'>一覧取得失敗</div>";
      return;
    }

    var items = (data && data.d && data.d.results) ? data.d.results : [];
    debug("items count: " + items.length);

    if (items.length > 0) {
      debug("first item json: " + JSON.stringify(items[0]));
    }

    if (!items.length) {
      area.innerHTML = "まだ質問はありません。";
      return;
    }

    var html = "<table border='1' style='border-collapse:collapse; width:100%;'>";
    html += "<tr>";
    html += "<th style='padding:8px;'>管理番号</th>";
    html += "<th style='padding:8px;'>質問内容</th>";
    html += "<th style='padding:8px;'>回答内容</th>";
    html += "</tr>";

    for (var i = 0; i < items.length; i++) {
      var item = items[i];

      debug("question field value = " + item[COL.QUESTION]);
      debug("answer field value = " + item[COL.ANSWER]);

      var title = item[COL.TITLE] || "";
      var question = stripHtml(item[COL.QUESTION] || "");
      var answer = stripHtml(item[COL.ANSWER] || "");

      html += "<tr>";
      html += "<td style='padding:8px;'>" + escapeHtml(title) + "</td>";
      html += "<td style='padding:8px;'>" + escapeHtml(question) + "</td>";
      html += "<td style='padding:8px;'>" + escapeHtml(answer || "未回答") + "</td>";
      html += "</tr>";
    }

    html += "</table>";
    area.innerHTML = html;
  });
}

// ================================
// 登録（まだダミー）
// ================================
function submitQuestion() {
  alert("一覧表示は動作中。登録処理は次で入れる。");
}

// ================================
// 初期化
// ================================
function init() {
  debug("init start");

  getCurrentUser(function (err, data) {
    if (err) {
      debug("currentuser error: " + err.message);
      setMessage("ログインユーザ取得失敗");
      return;
    }

    debug("user ok");

    var nameEl = document.getElementById("currentUserName");
    if (nameEl && data && data.d) {
      nameEl.textContent = data.d.Title || "取得失敗";
    }

    loadQuestions();
  });
}

window.onload = function () {
  debug("window load");

  var submitBtn = document.getElementById("submitBtn");
  var reloadBtn = document.getElementById("reloadBtn");

  if (submitBtn) submitBtn.onclick = submitQuestion;
  if (reloadBtn) reloadBtn.onclick = loadQuestions;

  init();
};
