<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>Q&Aフォーム</title>
</head>

<body>

<h2>Q&A質問フォーム</h2>

<div>
  ログインユーザ: <span id="currentUserName">取得中...</span>
</div>

<br>

区分:
<select id="category">
  <option value="システム">システム</option>
  <option value="手続き">手続き</option>
  <option value="その他">その他</option>
</select>

<br><br>

電話番号:
<input id="phoneNumber" />

<br><br>

質問内容:<br>
<textarea id="questionBody"></textarea>

<br><br>

<button id="submitBtn">登録</button>
<button id="reloadBtn">再読込</button>

<br><br>

<div id="message"></div>

<hr>

<h3>質問一覧</h3>
<div id="listArea">読込中...</div>

<hr>

<!-- 🔥 デバッグ欄 -->
<pre id="debugArea" style="background:black;color:#0f0;padding:10px;">
debug start
</pre>

<!-- JS -->
<script src="./qa-form.js"></script>

</body>
</html>
